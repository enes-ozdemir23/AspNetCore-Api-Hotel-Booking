@model List<ResultBookingDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
	int count = 0;
}

			<div class="card-title">
				<h4>Rezervasyonlar</h4>
			</div>
			<div class="table-responsive">
				<table class="table">
					<thead>


						<tr>
							<th>#</th>
							<th>Misafir</th>
							<th>Giriş Tarihi</th>
							<th>Çıkış Tarihi</th>
							<th>Durum</th>
							<th>Onaylandı</th>
							<th>İptal</th>
							<th>Beklet</th>
							<th>Güncelle</th>
							<th>Detaylar</th>
						</tr>

					</thead>
					<tbody>

						@foreach (var item in Model)
						{
							count++;
							<tr>
								<th>@count</th>
								<th>@item.Name</th>
								<td>@(((DateTime)item.Checkin).ToString("dd-MMM-yyyy"))</td>
								<td>@(((DateTime)item.Checkout).ToString("dd-MMM-yyyy"))</td>
								<td>
									<span class="badge badge-primary px-2">@item.Status</span>
								</td>
					<td><a href="/BookingAdmin/ApprovedReservation/@item.BookingID" class="btn mb-1 btn-rounded btn btn-primary">Onayla</a></td>
					<td><a href="/BookingAdmin/CancelledReservation/@item.BookingID" class="btn mb-1 btn-rounded btn btn-danger">İptal</a></td>
								<td><a href="#" class="btn mb-1 btn-rounded btn btn-warning">Beklet</a></td>
								<td><a href="#" class="btn mb-1 btn-rounded btn btn-info">Güncelle</a></td>
								<td><a href="#" class="btn mb-1 btn-rounded btn btn-dark">Detaylar</a></td>

							</tr>
						}

					</tbody>
				</table>
			</div>
