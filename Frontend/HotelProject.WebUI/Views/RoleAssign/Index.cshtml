@model List<HotelProject.EntityLayer.Concrete.AppUser>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<h1>Kullanıcı Listesi</h1>

<table class="table table-xs mb-0">
	<thead>
		<tr>
			<th>Kullanıcı</th>
			<th>Rol Ataması Yap</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{

			<tr>
				<td><img src="@item.ImageUrl" class=" rounded-circle mr-3" alt=""> @item.Name @item.SurName</td>
				<td><a href="/RoleAssign/AssingRole/@item.Id" class="btn btn-warning">Rol Ata</a></td>
			</tr>
		}
	</tbody>
</table>

