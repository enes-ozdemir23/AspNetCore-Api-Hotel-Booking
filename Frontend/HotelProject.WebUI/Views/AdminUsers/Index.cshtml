@model List<ResultAppUserDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}


<table class="table table-xs mb-0">
	<thead>
		<tr>
			<th>Kullanıcı</th>
			<th>Şehir</th>
			<th>Durum</th>
			<th>Sil</th>
			<th>Güncelle</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{

			<tr>
				<td><img src="@item.ImageUrl" class=" rounded-circle mr-3" alt=""> @item.Name @item.SurName</td>
				<td>@item.City</td>
				<td><i class="fa fa-circle-o text-success  mr-2"></i> Aktif</td>
				<td><a href="/Register/Index/" class="btn-rounded btn btn-warning">Sil</a> </td>
				<td><a href="/Register/Index/" class="btn-rounded btn btn-primary">Güncelle</a></td>
			</tr>
		}
	</tbody>
</table>
<br />
<a href="/Register/Index/" class="btn-rounded btn btn-primary">Yeni Kullanıcı Kaydet</a>